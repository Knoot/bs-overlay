services:
  nginx:
    image: nginx:1.27-alpine
    depends_on:
      - overlay
    ports:
      - "8080:80"
    volumes:
      - ./dist/overlay/browser:/usr/share/nginx/html:ro

  overlay:
    build:
      context: .
      dockerfile: Dockerfile.dev
    working_dir: /workspace
    command: sh -c "if [ ! -d node_modules/@angular ]; then npm ci || npm install; fi && npm run watch -- --poll 1000"
    volumes:
      - ./:/workspace
